# Claude API Key — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Ollama endpoint (default, running on host)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Primary local model
OLLAMA_PRIMARY_MODEL=gemma4:26b

# Fallback local model
OLLAMA_FALLBACK_MODEL=gemma4:e4b

# Claude model for complex tasks
CLAUDE_MODEL=claude-sonnet-4-20250514

# Workspace root (inside sandbox)
WORKSPACE_ROOT=/workspace

# Agent operation mode: HYBRID or LOCAL_ONLY
AGENT_MODE=HYBRID

# Security settings
REQUIRE_APPROVAL_FOR_WRITES=true
REQUIRE_APPROVAL_FOR_SHELL=true
AUDIT_LOG_ENABLED=true

# Conversation memory (sliding window)
MAX_CONVERSATION_TURNS=20

# ReAct loop iteration limit
MAX_ITERATIONS=10
